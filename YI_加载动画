local runService = game:GetService("RunService")
local rotateConn = nil
local approachConn = nil
local startApproach = nil
local textLabel = nil
local welcomeLabel = nil

function startRotating()
    rotateConn = runService.RenderStepped:Connect(function()
        for i = 1, 7 do
            angles[i] = angles[i] + speeds[i]
            local rad = math.rad(angles[i])
            local x = math.cos(rad) * radii[i]
            local y = math.sin(rad) * radii[i]
            local newPos = UDim2.new(0.5, x - 6, 0.5, y - 6)
            satellites[i].Position = newPos
            
            if lastPositions[i] then
                local lastX, lastY = lastPositions[i].X.Offset, lastPositions[i].Y.Offset
                createTrail(colors[colorOrder[i]], UDim2.new(0.5, lastX, 0.5, lastY))
            end
            lastPositions[i] = newPos
        end
    end)

    task.delay(rotateDuration, function()
        if rotateConn then rotateConn:Disconnect() end
        startApproach = tick()
        
        approachConn = runService.RenderStepped:Connect(function()
            local elapsed = tick() - startApproach
            local t = math.min(elapsed / approachDuration, 1)
            for i = 1, 7 do
                local newRadius = radiusStart - (radiusStart - radiusEnd) * t
                radii[i] = newRadius
                angles[i] = angles[i] + speeds[i]
                local rad = math.rad(angles[i])
                local x = math.cos(rad) * newRadius
                local y = math.sin(rad) * newRadius
                local newPos = UDim2.new(0.5, x - 6, 0.5, y - 6)
                satellites[i].Position = newPos
                
                if lastPositions[i] then
                    local lastX, lastY = lastPositions[i].X.Offset, lastPositions[i].Y.Offset
                    createTrail(colors[colorOrder[i]], UDim2.new(0.5, lastX, 0.5, lastY))
                end
                lastPositions[i] = newPos
            end
            if t >= 1 then
                if approachConn then approachConn:Disconnect() end
                onCollision()
            end
        end)
    end)
end

