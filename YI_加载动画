function breakApart(title, content)
    local objectsToBreak = {
        centerOuter, centerInner, background, title, content
    }
    
    for _, obj in ipairs(objectsToBreak) do
        if obj then
            obj.Visible = false
        end
    end
    
    local particleCount = 150
    for i = 1, particleCount do
        local colorChoice = math.random()
        local color
        if colorChoice < 0.7 then
            color = Color3.fromRGB(170 + math.random(50), 200 + math.random(50), 230 + math.random(25))
        else
            local rand = math.random(1, 7)
            color = colors[colorOrder[rand]]
        end
        
        local particle = Instance.new("Frame")
        local size = math.random(4, 10)
        particle.Size = UDim2.new(0, size, 0, size)
        particle.BackgroundColor3 = color
        particle.BackgroundTransparency = 0.2
        particle.BorderSizePixel = 0
        particle.Parent = ScreenGui
        
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(1, 0)
        corner.Parent = particle
        
        local startX = math.random(-200, 200)
        local startY = math.random(-200, 200)
        particle.Position = UDim2.new(0.5, startX - size/2, 0.5, startY - size/2)
        
        local angle = math.random() * 2 * math.pi
        local distance = math.random(400, 1000)
        local targetX = startX + math.cos(angle) * distance
        local targetY = startY + math.sin(angle) * distance
        local rotSpeed = math.random(-180, 180)
        
        local move = tweenService:Create(particle, TweenInfo.new(1.0, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {Position = UDim2.new(0.5, targetX - size/2, 0.5, targetY - size/2), Rotation = rotSpeed})
        move:Play()
        
        local fade = tweenService:Create(particle, TweenInfo.new(0.8, Enum.EasingStyle.Quad),
            {BackgroundTransparency = 1})
        fade:Play()
        
        task.delay(1.2, function()
            particle:Destroy()
        end)
    end
    
    task.delay(1.3, function()
        if ScreenGui then ScreenGui:Destroy() end
    end)
end

